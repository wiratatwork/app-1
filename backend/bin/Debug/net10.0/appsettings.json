{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "BaseUrl": "http://localhost:7890",
    "PublicBaseUrl": "http://localhost:7890",
    "Realm": "toyota",
    "ClientId": "app-1",
    "Scope": "openid profile email",
    "Audience": "account",
    "RequireHttpsMetadata": false,
    "ValidAudiences": ["account", "app-1"]
  },
  "Bff": {
    "PublicBaseUrl": "http://localhost:4201",
    "SessionCookieName": "app1_bff_session",
    "PendingLoginCookieName": "app1_bff_pending",
    "SessionIdleMinutes": 30,
    "EnableSilentSso": true,
    "PostLoginPath": "/",
    "PostLogoutPath": "/login"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:4201"]
  }
}
